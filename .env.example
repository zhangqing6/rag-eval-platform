# SQLite（默认即可；Docker 内亦为 ./data/eval.db）
DATABASE_URL=sqlite:///./data/eval.db

# LLM-as-judge：兼容 OpenAI Chat Completions（也可用 Ollama: http://host.docker.internal:11434/v1）
JUDGE_API_KEY=
JUDGE_BASE_URL=https://api.openai.com/v1
JUDGE_MODEL=gpt-4o-mini

# 批量调用 Agent 时的并发与超时
HTTP_TIMEOUT_SECONDS=120
MAX_CONCURRENT_REQUESTS=5

# 简易评测台 / scripts/mock_agent：本机 Ollama
OLLAMA_BASE=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
# 限制 Ollama 输出长度，降低 eval_count / 耗时（示例 384；不配则不限）
# OLLAMA_NUM_PREDICT=384

# scripts/mock_agent.py 专用（可选）
# OLLAMA_SYSTEM=
